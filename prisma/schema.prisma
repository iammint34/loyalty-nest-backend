generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  id              String        @id @default(cuid())
  phoneNumber     String        @unique @map("phone_number")
  firstName       String?       @map("first_name")
  lastName        String?       @map("last_name")
  totalPoints     Int           @default(0) @map("total_points")
  availablePoints Int           @default(0) @map("available_points")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  transactions    Transaction[]
  redemptions     Redemption[]

  @@map("customers")
}

model OtpCode {
  id          String   @id @default(cuid())
  phoneNumber String   @map("phone_number")
  code        String
  attempts    Int      @default(0)
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phoneNumber])
  @@map("otp_codes")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs    AuditLog[]

  @@map("admin_users")
}

model Transaction {
  id                 String     @id @default(cuid())
  posTransactionRef  String     @unique @map("pos_transaction_ref")
  orderAmount        Decimal    @map("order_amount") @db.Decimal(10, 2)
  pointsEarned       Int        @default(0) @map("points_earned")
  branchCode         String?    @map("branch_code")
  items              Json?
  status             String     @default("pending")
  promotionId        String?    @map("promotion_id")
  promotion          Promotion? @relation(fields: [promotionId], references: [id])
  customerId         String?    @map("customer_id")
  customer           Customer?  @relation(fields: [customerId], references: [id])
  qrCode             QrCode?
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([status])
  @@index([branchCode])
  @@index([promotionId])
  @@map("transactions")
}

model Promotion {
  id          String          @id @default(cuid())
  name        String          @db.VarChar(255)
  description String?         @db.Text
  type        String          // standard, multiplier, bonus
  isActive    Boolean         @default(true) @map("is_active")
  startDate   DateTime        @map("start_date")
  endDate     DateTime        @map("end_date")
  rules       PromotionRule[]
  transactions Transaction[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([startDate, endDate])
  @@map("promotions")
}

model PromotionRule {
  id            String    @id @default(cuid())
  promotionId   String    @map("promotion_id")
  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  minSpend      Decimal   @default(0) @map("min_spend") @db.Decimal(10, 2)
  pointsAwarded Int       @default(0) @map("points_awarded")
  multiplier    Float     @default(1.0)
  dayOfWeek     String?   @map("day_of_week") // monday-sunday or null for any day
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([promotionId])
  @@map("promotion_rules")
}

model QrCode {
  id            String      @id @default(cuid())
  code          String      @unique
  transactionId String      @unique @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  scannedAt     DateTime?   @map("scanned_at")
  expiresAt     DateTime    @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([code])
  @@map("qr_codes")
}

model Reward {
  id          String       @id @default(cuid())
  name        String       @db.VarChar(255)
  description String?      @db.Text
  type        String       // free_item, discount, voucher
  pointsCost  Int          @map("points_cost")
  stockLimit  Int?         @map("stock_limit")
  stockUsed   Int          @default(0) @map("stock_used")
  isActive    Boolean      @default(true) @map("is_active")
  validFrom   DateTime     @map("valid_from")
  validUntil  DateTime     @map("valid_until")
  redemptions Redemption[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([validFrom, validUntil])
  @@map("rewards")
}

model Redemption {
  id             String    @id @default(cuid())
  customerId     String    @map("customer_id")
  customer       Customer  @relation(fields: [customerId], references: [id])
  rewardId       String    @map("reward_id")
  reward         Reward    @relation(fields: [rewardId], references: [id])
  pointsSpent    Int       @map("points_spent")
  redemptionCode String    @unique @map("redemption_code")
  status         String    @default("active") // active, verified, expired, cancelled
  redeemedAt     DateTime  @default(now()) @map("redeemed_at")
  verifiedAt     DateTime? @map("verified_at")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([customerId])
  @@index([rewardId])
  @@index([status])
  @@index([redemptionCode])
  @@map("redemptions")
}

model AuditLog {
  id          String    @id @default(cuid())
  adminUserId String    @map("admin_user_id")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  action      String    // create, update, delete, verify
  entity      String    // reward, redemption, promotion, etc.
  entityId    String    @map("entity_id")
  details     Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([adminUserId])
  @@index([entity])
  @@index([action])
  @@map("audit_logs")
}
